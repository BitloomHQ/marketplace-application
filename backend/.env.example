# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DB_NAME=home_services_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# Redis (Django Channels / WebSockets)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Server-side only — never put this in frontend/.env or VITE_* variables
# Enable "Places API (New)" (autocomplete + searchText) and "Geocoding API" in Google Cloud
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
